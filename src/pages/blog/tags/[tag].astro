---
import Layout from "../../../layouts/Page.astro";

import { getCollection } from "astro:content";
import FormattedDate from "../../../components/FormattedDate.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;

const postsByYear = posts.reduce((acc, post) => {
  const year = post.data.pubDate.getFullYear();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(post);
  return acc;
}, {});
---

<Layout title={`Blog | Tag: ${tag}`} description={`Blog posts tagged with "${tag}".`}>
  <main>
    <article class="archive">
      <h1>Posts tagged with <span class="tag is-dark is-medium">{tag}</span></h1>
      <p class="has-text-grey mb-4">
        <a href="/blog/">&larr; All posts</a>
      </p>
      <ul>
        {
          Object.keys(postsByYear)
            .reverse()
            .map(year => (
              <li class="archive-item">
                <h2>{year}</h2>
                <ul>
                  {postsByYear[year].map(post => (
                    <li class="archive-item">
                      <FormattedDate date={post.data.pubDate} />
                      <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                      {post.data.tags && post.data.tags.length > 0 && (
                        post.data.tags.map((t) => (
                          <a href={`/blog/tags/${t}/`} class:list={["tag", "ml-1", t === tag ? "is-primary" : "is-dark"]} style="font-size: 0.7rem; padding: 0.2em 0.5em; height: auto;">{t}</a>
                        ))
                      )}
                      {post.data.description && (
                        <p class="has-text-grey is-size-7 mb-0">{post.data.description}</p>
                      )}
                    </li>
                  ))}
                </ul>
              </li>
            ))
        }
      </ul>
    </article>
  </main>
</Layout>
