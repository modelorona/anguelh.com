---
import HeaderLink from "./HeaderLink.astro";
import Icon from "./Icon.astro";
---

<header>
  <nav class="navbar" aria-label="main navigation">
    <div class="navbar-brand">
      <button
        class="navbar-burger"
        aria-label="menu"
        aria-expanded="false"
        data-target="nav-menu"
      >
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>
    </div>

    <div id="nav-menu" class="navbar-menu">
      <div class="navbar-start">
        <HeaderLink class="navbar-item" href="/">About</HeaderLink>
        <HeaderLink class="navbar-item" href="/projects">Projects</HeaderLink>
        <HeaderLink class="navbar-item" href="/blog">Blog</HeaderLink>
        <HeaderLink class="navbar-item" href="/resume">Resume/CV</HeaderLink>
        <button class="navbar-item" id="activate-clippy" style="background: none; border: none; cursor: pointer; font-size: inherit; color: inherit;">Harmless surprise</button>
      </div>

      <div class="navbar-end">
        <div class="navbar-item">
          <div class="buttons">
            <a class="button" href="https://github.com/modelorona" target="_blank" referrerpolicy="no-referrer" aria-label="go to github">
              <span class="icon is-medium">
                <Icon name="github" />
              </span>
            </a>
            <a class="button" href="https://www.linkedin.com/in/ahristozov/" target="_blank" referrerpolicy="no-referrer" aria-label="go to linkedin">
              <span class="icon is-medium">
                <Icon name="linkedin" />
              </span>
            </a>
            <button class="button" id="toggle-form-modal" aria-label="show contact form">
              <span class="icon is-medium">
                <Icon name="envelope" />
              </span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="modal" id="form-modal">
      <div class="modal-background has-background-dark-bis"></div>
      <div class="modal-content">
        <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
          <label class="label">Name</label>
          <div class="control py-4">
            <input class="input" type="text" placeholder="Your name" name="name" />
          </div>

          <br />

          <label class="label">Email</label>
          <div class="control py-4">
            <input class="input" type="email" placeholder="Your email" name="email" />
          </div>

          <br />

          <label class="label">Message</label>
          <div class="control py-4">
            <textarea class="textarea" placeholder="Your message" name="message"></textarea>
          </div>

          <p class="hidden">
            <label>Don’t fill this out if you’re human: <input name="bot-field" /></label>
          </p>

          <br />

          <div class="control">
            <button class="button is-primary">Submit</button>
          </div>
        </form>
      </div>
      <button id="close-form-modal" class="modal-close is-large" aria-label="close"></button>
    </div>
  </nav>
</header>

<div class="my-clippy"></div>

<script type="module" defer>
  const activate = document.getElementById("activate-clippy");

  activate.addEventListener("click", async () => {
    const clippy = await import("https://unpkg.com/clippyts@1.0.4/dist/index.js");
    clippy.default.load({
      name: "Clippy",
      selector: "my-clippy",
      successCb: agent => {
        agent.show();
        agent.speak("Hello, I am Clippy!");
        agent.animate();
        agent.speak("Thanks for visiting the site. I hope you enjoy your stay.");
        setInterval(() => {
          agent.animate();
        }, 10000);
      },
      failCb: err => {
        console.log(err);
      },
    });
  });
</script>
